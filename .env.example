GPT5_NANO_API_KEY=
GPT5_NANO_BASE_URL=
GPT5_NANO_MODEL=gpt-5-nano
AI_SYSTEM_PROMPT=You are a VHF radio assistant called Mike. Keep replies under 2 sentences unless asked for longer responses. Use clear statements and avoid long paragraphs. If unsure, ask one short clarifying question. Never mention being an AI.
LLM_TIMEOUT_SECONDS=20
LLM_MAX_RETRIES=3
LLM_BACKOFF_BASE_SECONDS=1
RADIOBUDDY_RESET_PHRASES=reset radiobuddy|reset radio buddy|clear history|reset conversation|reset brain|start fresh|wipe brains|history delete|delete history|forget history|clear brain|forget brain|forget everything|forget all|mike, forget|mike, forget history|mike, forget brain|mike, forget everything|mike, forget all|mike, reset|mike, reset conversation|mike, reset brain|mike, start fresh|mike, wipe brains|mike, history delete|mike, delete history|mike, clear brain|new mike

WHISPER_API_KEY=
STT_PROVIDER=whisper
STT_MODEL=whisper-1
STT_LANGUAGE=ru
STT_TIMEOUT_SECONDS=20
STT_MAX_RETRIES=3
STT_BACKOFF_BASE_SECONDS=1

MACOS_TTS_VOICE=Milena
MACOS_TTS_RATE=180
# Linux: path to Piper .onnx voice model (e.g. from: python3 -m piper.download_voices ru_RU-irina-medium)
PIPER_MODEL_PATH=

AUDIO_INPUT_DEVICE=
AUDIO_OUTPUT_DEVICE=
SAMPLE_RATE=44100
CHUNK_SECONDS=3

VOX_THRESHOLD_DB=-35
VOX_MIN_DURATION_MS=300
VOX_SILENCE_TIMEOUT_SEC=5

# Operating mode:
#   ai       - full STT + AI + TTS
#   dummy    - offline dummy STT + dummy AI reply
#   repeater - no STT/AI/TTS, just record and repeat
MODE=ai

