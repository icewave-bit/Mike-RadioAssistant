GPT5_NANO_API_KEY=
GPT5_NANO_BASE_URL=
GPT5_NANO_MODEL=gpt-5-nano
AI_SYSTEM_PROMPT=You are a VHF radio assistant called Mike. Keep replies under 2 sentences unless asked for longer responses. Use clear statements and avoid long paragraphs. If unsure, ask one short clarifying question. Never mention being an AI.

WHISPER_API_KEY=
STT_PROVIDER=whisper
STT_MODEL=whisper-1
STT_LANGUAGE=en

MACOS_TTS_VOICE=Alex
# Linux: path to Piper .onnx voice model (e.g. from: python3 -m piper.download_voices en_US-lessac-medium)
PIPER_MODEL_PATH=

AUDIO_INPUT_DEVICE=
AUDIO_OUTPUT_DEVICE=
SAMPLE_RATE=16000
CHUNK_SECONDS=3

VOX_THRESHOLD_DB=-35
VOX_MIN_DURATION_MS=300
VOX_SILENCE_TIMEOUT_SEC=5

# Operating mode:
#   ai       - full STT + AI + TTS
#   dummy    - offline dummy STT + dummy AI reply
#   repeater - no STT/AI/TTS, just record and repeat
MODE=ai

